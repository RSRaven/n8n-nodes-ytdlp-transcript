{
  "name": "@rsraven/n8n-nodes-ytdlp-transcript",
  "version": "0.1.1",
  "description": "n8n node for extracting video transcripts using yt-dlp with browser cookie support",
  "keywords": ["n8n-community-node", "n8n", "n8n-node", "youtube", "transcript", "yt-dlp", "video", "subtitles"],
  "license": "MIT",
  "homepage": "https://github.com/RSRaven/n8n-nodes-ytdlp-transcript#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/RSRaven/n8n-nodes-ytdlp-transcript.git"
  },
  "bugs": {
    "url": "https://github.com/RSRaven/n8n-nodes-ytdlp-transcript/issues"
  },
  "author": {
    "name": "Mykyta Lovygin",
    "url": "https://github.com/RSRaven"
  },
  "main": "index.js",
  "engines": {
    "node": ">=20.16.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp nodes/YtDlpTranscript/ytdlp.svg dist/nodes/YtDlpTranscript/",
    "dev": "tsc --watch"
  },
  "files": ["dist"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/YtDlpTranscript/YtDlpTranscript.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.16.16",
    "typescript": "^5.1.3",
    "n8n-workflow": "^1.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
